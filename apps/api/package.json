{
  "name": "@changepath/api",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "type-check": "XDG_CACHE_HOME=../../.cache prisma generate && tsc --noEmit",
    "lint": "echo 'TODO: add eslint to api'",
    "test": "XDG_CACHE_HOME=../../.cache prisma generate && vitest run",
    "db:migrate": "prisma migrate dev",
    "db:seed": "tsx prisma/seed.ts",
    "db:reset": "prisma migrate reset --force",
    "db:generate": "XDG_CACHE_HOME=../../.cache prisma generate"
  },
  "dependencies": {
    "@changepath/engine": "*",
    "@changepath/shared": "*",
    "@prisma/client": "^6.6.0",
    "fastify": "^5.3.3",
    "@fastify/cors": "^11.0.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "prisma": "^6.6.0",
    "tsx": "^4.19.0",
    "typescript": "^5.8.3",
    "vitest": "^4.1.2",
    "@types/node": "^22.0.0"
  }
}
